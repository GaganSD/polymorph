# Copy to `.env` and fill in. `.env` is gitignored; this template is tracked.
# Load with: `set -a; source .env; set +a`

# AWS Bedrock — primary teacher (deepseek.v3.2) uses the AWS credential chain
# (logged-in CLI / profile / SSO), so no key — just the region. DeepSeek V3.2 is
# ON_DEMAND in us-east-1, us-west-2, eu-north-1.  (SSO login needs botocore[crt].)
AWS_REGION=us-east-1

# OpenRouter API key — free/open-weight secondary (https://openrouter.ai/keys).
OPENROUTER_API_KEY=sk-or-...

# Vercel AI Gateway key — LEGACY. STRICT: only alibaba/qwen3.7-max permitted.
# VERCEL_AI_GATEWAY_KEY=vck_...
