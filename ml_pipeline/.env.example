# Copy to `.env` and fill in. `.env` is gitignored; this template is tracked.
# Load with: `set -a; source .env; set +a`

# AWS Bedrock — the two teachers (deepseek.v3.2 + minimax.minimax-m2.1) use the
# AWS credential chain (logged-in CLI / profile / SSO), so no key — just the
# region. Both are ON_DEMAND in us-east-1, us-west-2, eu-north-1.
# (SSO login needs botocore[crt].)
AWS_REGION=us-east-1

# Vercel AI Gateway key — LEGACY. STRICT: only alibaba/qwen3.7-max permitted.
# VERCEL_AI_GATEWAY_KEY=vck_...
